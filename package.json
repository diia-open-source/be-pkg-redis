{
    "name": "@diia-inhouse/redis",
    "version": "3.1.23",
    "type": "module",
    "description": "Redis services - redlock, pubsub, cache and store",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "repository": "https://github.com/diia-open-source/be-pkg-redis",
    "author": "Diia",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsdown",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "resolutions": {
        "@babel/traverse": "7.25.9"
    },
    "dependencies": {
        "ioredis": "5.10.1",
        "redis-semaphore": "5.7.0"
    },
    "peerDependencies": {
        "@diia-inhouse/env": ">=3.0.0",
        "@diia-inhouse/errors": ">=2.0.0",
        "@diia-inhouse/types": ">=13.0.0",
        "@diia-inhouse/validators": ">=2.0.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "7.0.1",
        "@diia-inhouse/diia-logger": "4.4.5",
        "@diia-inhouse/env": "3.3.27",
        "@diia-inhouse/errors": "2.2.1",
        "@diia-inhouse/oxc-config": "1.11.0",
        "@diia-inhouse/test": "8.2.16",
        "@diia-inhouse/types": "13.3.0",
        "@diia-inhouse/validators": "2.2.32",
        "@types/node": "25.6.2",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "eslint-plugin-prettier": "5.5.5",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "semantic-release": "25.0.3",
        "tsdown": "0.22.0",
        "typescript": "5.9.3",
        "vitest": "4.1.5",
        "vitest-mock-extended": "4.0.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    },
    "license": "SEE LICENCE IN LICENCE.md"
}
